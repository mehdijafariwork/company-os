# Pooled Postgres connection string (Supabase Supavisor / Neon pooler / equivalent).
# For serverless: use the transaction-mode pooler (port 6543 on Supabase) — `prepare: false` is already set in the client.
# Never commit a real value. Vercel: set in Project → Settings → Environment Variables. Local: copy to .env.local.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
